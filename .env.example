# ROM Curator — environment variables
# Copy to .env and fill in your values. Never commit .env.

# ROMM instance URL — required for romm-sync (no trailing slash)
ROMM_URL=https://your-romm-instance.example.com

# ROMM API token — required for romm-sync
# Generate from your ROMM instance: Settings → API Keys
ROMM_TOKEN=your_token_here
