# Python bytecode
__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/
env/

# Secrets — put ROMM_TOKEN here, never in config.yaml
.env

# Database — generated by: python3 romcurator.py inventory
*.sqlite
*.sqlite3

# MAME machine XML — large generated file (260+ MB), not committed
# Regenerate with: mame -listxml > mame.xml
mame*.xml

# Generated reports
reports/

# Runtime cache
cache/

# Local test ROM fixtures — not committed (use your own roms-test/ tree)
roms-test/

# macOS / Windows clutter
.DS_Store
Thumbs.db
desktop.ini

# Editor
.idea/
.vscode/
*.swp
*.swo
